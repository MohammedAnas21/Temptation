{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "installCommand": "npm install --no-audit --no-fund",
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/temptations-cafe.apk",
      "destination": "https://github.com/MohammedAnas21/Temptation/releases/download/v1.0.0/temptations-cafe.apk",
      "permanent": false
    }
  ]
}
